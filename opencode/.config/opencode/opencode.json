{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-mem",
    "@plannotator/opencode@latest",
    "@spoons-and-mirrors/subtask2@latest",
    "./plugins/revdiff-plan-review.ts",
    "@prevalentware/opencode-goal-plugin"
  ],
  "mcp": {
    "semble": {
      "command": [
        "uvx",
        "--from",
        "semble[mcp]",
        "semble"
      ],
      "type": "local",
      "enabled": true
    },
    "mcp-dap-server": {
      "type": "local",
      "command": [
        "mcp-dap-server"
      ],
      "enabled": true
    }
  },
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "timeout": false
      },
      "models": {
        "qwen": {
          "name": "qwen",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  }
}
