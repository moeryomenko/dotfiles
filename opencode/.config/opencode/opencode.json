{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-mem",
    "@plannotator/opencode@latest",
    "@spoons-and-mirrors/subtask2@latest",
    "./plugins/revdiff-plan-review.ts"
  ],
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "timeout": false
      },
      "models": {
        "qwen": {
          "name": "qwen",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "agent": {
    "architector": {
      "description": "Spec Architect & Iterative Refiner — Works with user to produce final .spec.md",
      "mode": "primary",
      "model": "llama/qwen",
      "temperature": 0.1,
      "steps": 25,
      "tools": {
        "write": true,
        "edit": true,
        "bash": false,
        "todowrite": true,
        "question": true,
        "webfetch": true,
        "websearch": true,
        "skill": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/planner.md}"
    },
    "plan": {
      "description": "Implementation Planner — Decomposes approved .spec.md into task-ordered implementation_plan.md",
      "mode": "primary",
      "model": "llama/qwen",
      "temperature": 0.2,
      "steps": 15,
      "tools": {
        "write": true,
        "edit": true,
        "bash": false,
        "todowrite": true,
        "question": true,
        "skill": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/plan_impl.md}"
    },
    "build": {
      "description": "Execution Orchestrator — Coordinates @engineer/@reviewer/@qa/@commiter pipeline, owns delivery",
      "mode": "primary",
      "model": "llama/qwen",
      "temperature": 0.3,
      "steps": 30,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true,
        "question": true,
        "lsp": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/build.md}"
    },
    "explorer": {
      "description": "Senior Systems Researcher — Eliminates unknowns before implementation",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "webfetch": true,
        "websearch": true,
        "skill": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/explorer.md}"
    },
    "engineer": {
      "description": "Production-grade Software Engineer — Implementation specialist",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.25,
      "tools": {
        "write": true,
        "edit": true,
        "skill": true,
        "question": true,
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true
      },
      "prompt": "{file:./prompts/engineer.md}"
    },
    "reviewer": {
      "description": "Spec Compliance Auditor — Verifies implementation against .spec.md contract",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "read": true,
        "grep": true,
        "glob": true,
        "lsp": true,
        "skill": true
      },
      "prompt": "{file:./prompts/reviewer.md}"
    },
    "qa": {
      "description": "Spec Verifier — Tests implementation against Verification Contract",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.2,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "grep": true,
        "glob": true,
        "lsp": true,
        "skill": true,
        "question": true
      },
      "prompt": "{file:./prompts/qa.md}"
    },
    "reflector": {
      "description": "Systems Architect & Meta-Analysis — Post-implementation feedback loop, collects spec ambiguities from all agents",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.15,
      "tools": {
        "write": false,
        "read": true,
        "grep": true,
        "skill": true
      },
      "prompt": "{file:./prompts/reflector.md}"
    },
    "commiter": {
      "description": "Conventional Commits Specialist — Generates commit messages explaining WHY changes were made and applies them via git",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "grep": true,
        "glob": true,
        "write": true
      },
      "prompt": "{file:./prompts/commiter.md}"
    }
  }
}
