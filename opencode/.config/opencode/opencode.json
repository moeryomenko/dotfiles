{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-mem",
    "@plannotator/opencode@latest",
    "@spoons-and-mirrors/subtask2@latest",
    "./plugins/revdiff-plan-review.ts",
    "@prevalentware/opencode-goal-plugin"
  ],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true
    },
    "semble": {
      "command": [
        "uvx",
        "--from",
        "semble[mcp]",
        "semble"
      ],
      "type": "local",
      "enabled": true
    },
    "mcp-dap-server": {
      "type": "local",
      "command": [
        "mcp-dap-server"
      ],
      "enabled": true
    }
  }
}
