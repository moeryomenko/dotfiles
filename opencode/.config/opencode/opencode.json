{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-mem",
    "@plannotator/opencode@latest",
    "@spoons-and-mirrors/subtask2@latest"
  ],
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "timeout": false
      },
      "models": {
        "qwen": {
          "name": "qwen",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "agent": {
    "architector": {
      "description": "Spec Architect & Iterative Refiner — Works with user to produce final .spec.md",
      "mode": "primary",
      "model": "llama/qwen",
      "temperature": 0.1,
      "steps": 25,
      "tools": {
        "write": true,
        "edit": true,
        "bash": false,
        "todowrite": true,
        "question": true,
        "webfetch": true,
        "websearch": true,
        "skill": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/planner.md}"
    },
    "plan": {
      "description": "Implementation Planner — Decomposes approved .spec.md into task-ordered implementation_plan.md",
      "mode": "primary",
      "model": "llama/qwen",
      "temperature": 0.2,
      "steps": 15,
      "tools": {
        "write": true,
        "edit": true,
        "bash": false,
        "todowrite": true,
        "question": true,
        "skill": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/plan_impl.md}"
    },
    "build": {
      "description": "Staff+ Engineer & Execution Orchestrator — Delegates to subagents, owns delivery",
      "mode": "primary",
      "model": "llama/qwen",
      "temperature": 0.3,
      "steps": 30,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true,
        "question": true,
        "lsp": true,
        "glob": true,
        "grep": true
      }
    },
    "explorer": {
      "description": "Senior Systems Researcher — Eliminates unknowns before implementation",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "webfetch": true,
        "websearch": true,
        "skill": true,
        "read": true,
        "glob": true,
        "grep": true
      },
      "prompt": "{file:./prompts/explorer.md}"
    },
    "engineer": {
      "description": "Production-grade Software Engineer — Implementation specialist",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.25,
      "tools": {
        "write": true,
        "edit": true,
        "skill": true,
        "question": true,
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true
      },
      "prompt": "{file:./prompts/engineer.md}"
    },
    "reviewer": {
      "description": "Spec Compliance Auditor — Verifies implementation against .spec.md contract",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "read": true,
        "grep": true,
        "glob": true,
        "lsp": true,
        "skill": true
      },
      "prompt": "{file:./prompts/reviewer.md}"
    },
    "qa": {
      "description": "Spec Verifier — Tests implementation against Verification Contract",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.2,
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "grep": true,
        "glob": true,
        "lsp": true,
        "skill": true,
        "question": true
      },
      "prompt": "{file:./prompts/qa.md}"
    },
    "reflector": {
      "description": "Systems Architect & Meta-Analysis — Post-implementation feedback loop",
      "mode": "subagent",
      "model": "llama/qwen",
      "temperature": 0.15,
      "tools": {
        "write": false,
        "read": true,
        "grep": true,
        "skill": true
      },
      "prompt": "{file:./prompts/reflector.md}"
    },
    "goreview": {
      "mode": "primary",
      "description": "Go code review without modifications",
      "model": "llama/qwen",
      "temperature": 0.1,
      "prompt": "{file:./prompts/goreview.txt}",
      "color": "#00758F",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "go vet *": "allow",
          "staticcheck *": "allow",
          "errcheck *": "allow",
          "golangci-lint run *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "grep -r * *.go": "allow",
          "find * -name '*.go'": "allow"
        }
      }
    }
  }
}
