[core]
	editor = nvim
	excludesfile = ~/.config/gitignore-global
[user]
	name = Maxim Eryomenko
	email = moeryomenko@gmail.com
	signingkey = 15AE73521DFBFAED
[alias]
	clog = log --format='%C(dim)%h    %<(14)%ad    %<(24)%an    %C(reset)%s' --date=relative
	glog = log --graph --all --date=relative --pretty=format:'%Cred%h %Creset%<|(50,trunc)%s %C(bold blue)<%an>%Creset %Cgreen(%cd)%Creset%C(auto)%d'
	noed = commit --amend --no-edit
	a    = add
	c    = clone
	d    = diff
	r    = rebase -i
	co   = checkout
	cm   = commit -s
	s    = status
	fp   = format-patch
	sm   = send-email
[commit]
	gpgsign = true
[sendemail]
	smtpserver = smtp.gmail.com
	smtpserverport = 587
	smtpencryption = tls
[init]
	defaultBranch = main
[url "git@github.com:"]
	insteadOf = https://github.com/
[grep]
	lineNumber = true
