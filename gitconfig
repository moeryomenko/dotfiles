[core]
	editor = nvim
	excludesfile = ~/.config/gitignore-global
	pager = less -F -X
[user]
	name = Maxim Eryomenko
	email = moeryomenko@gmail.com
	signingkey = 15AE73521DFBFAED
[alias]
	clog = log --format='%C(dim)%h    %<(14)%ad    %<(24)%an    %C(reset)%s' --date=relative
	glog = log-graph
	noed = commit --amend --no-edit
	rs   = remote set-url
	rg   = remote get-url
	h    = log --decorate --all --oneline --graph
	a    = add
	c    = clone
	d    = diff
	rb   = rebase -i
	rc   = rabase --continue
	co   = checkout
	cm   = commit -s
	cmm  = commit-modefied
	s    = status
	fp   = format-patch
	sm   = send-email
	rc   = resolve-conflicts
	sc   = secret
	rs   = restore
	rmb  = remove-merged-branches
	cp   = cherry-pick
	cpc  = cherry-pick --continue
	po   = push-origin
	pfo  = push-force-origin
	rt   = regression-testing
[commit]
	gpgsign  = true
	template = ~/.config/gitmessage
[sendemail]
	smtpserver = smtp.gmail.com
	smtpserverport = 587
	smtpencryption = tls
[init]
	defaultBranch = main
[url "git@github.com:"]
	insteadOf = https://github.com/
[grep]
	lineNumber = true
[rerere]
	enabled = true
	autoUpdate = true
[fetch]
	prune = true
[color "status"]
	added = green
	changed = yellow
	untracked = blue
[protocol]
	version = 2
