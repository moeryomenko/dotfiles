[core]
	editor = nvim
	excludesfile = ~/.config/gitignore-global
	pager = bat
[user]
	name = Maxim Eryomenko
	email = moeryomenko@gmail.com
	signingkey = 15AE73521DFBFAED
[alias]
	clog = log --format='%C(dim)%h    %<(14)%ad    %<(24)%an    %C(reset)%s' --date=relative
	glog = log --graph --all --date=relative --pretty=format:'%Cred%h %Creset%<|(100,trunc)%s %C(bold blue)<%an>%Creset %Cgreen(%cd)%Creset%C(auto)%d'
	noed = commit --amend --no-edit
	a    = add
	c    = clone
	d    = diff --word-diff
	rb   = rebase -i
	co   = checkout
	cm   = commit -s
	s    = status
	fp   = format-patch
	sm   = send-email
	rc   = "!git diff --name-only --relative -z --diff-filter=U | xargs -0 nvim -f -c 'tab all' -c 'tabd Gvdiff!'"
	sc   = secret
	rs   = restore
	rmb  = remove-merged-branches
[commit]
	gpgsign  = true
	template = ~/.config/gitmessage
[sendemail]
	smtpserver = smtp.gmail.com
	smtpserverport = 587
	smtpencryption = tls
[init]
	defaultBranch = main
[url "git@github.com:"]
	insteadOf = https://github.com/
[grep]
	lineNumber = true
